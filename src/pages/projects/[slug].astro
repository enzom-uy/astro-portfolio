---
import { getCollection, type CollectionEntry } from 'astro:content';
import readingTime from 'reading-time';
import type { ProjectSchema } from '../../content/config';
import PostLayout from '../../layouts/PostLayout.astro';
import { getBlogImage, getProjectImage } from '../../utils';

export async function getStaticPaths() {
    const postEntries = await getCollection('projects');
    return postEntries.map(entry => ( {
        params: { slug: entry.slug }, props: { entry },
    } ));
}

interface Props {
    entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const project : ProjectSchema = entry.data;
const { Content } = await entry.render();

const stats = readingTime(entry.body || '');

let heroImage;
if (project.heroImage) {
    heroImage = await getProjectImage(entry.slug, project?.heroImage);
}

---

<PostLayout
    title={project.title}
    description={project.description}
    publishDate={project.publishDate}
    updatedDate={project.updatedDate}
    heroImage={heroImage?.default}
    heroImageType="banner"
    readingTime={stats.text}
    tags={project.tags}
    type={project.type}
    stack={project.stack}
>
    <Content/>
</PostLayout>
