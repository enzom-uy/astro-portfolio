---
import { getCollection, type CollectionEntry } from 'astro:content';
import readingTime from 'reading-time';
import type { ProjectSchema } from '../../content/config';
import PostLayout from '../../layouts/PostLayout.astro';
import { getBlogImage } from '../../utils';

export async function getStaticPaths() {
    const postEntries = await getCollection('projects');
    return postEntries.map(entry => ( {
        params: { slug: entry.slug }, props: { entry },
    } ));
}

interface Props {
    entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const post : ProjectSchema = entry.data;
const { Content } = await entry.render();

const stats = readingTime(entry.body || '');

let heroImage;
if (post.heroImage) {
    heroImage = await getBlogImage(entry.slug, post?.heroImage);
}

---

<PostLayout
    title={post.title}
    description={post.description}
    publishDate={post.publishDate}
    updatedDate={post.updatedDate}
    heroImage={heroImage?.default}
    readingTime={stats.text}
    tags={post.tags}
    type={post.type}
    stack={post.stack}
>
    <Content/>
</PostLayout>
