---
import { getCollection } from "astro:content";
import SocialMediaIcons from "../components/SocialMediaIcons.astro";
import MatrixBackground from "../components/MatrixBackground.astro";
import ProjectItem from "../components/ProjectItem.astro";
import Card from "../components/ui/Card.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortMDByDate } from "../utils";
import TerminalHeader from "../components/ui/TerminalHeader.astro";
import TerminalPrompt from "../components/ui/TerminalPrompt.astro";
import InfoRow from "../components/ui/InfoRow.astro";
import ExternalLink from "../components/ui/ExternalLink.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import Divider from "../components/ui/Divider.astro";
import PostList from "../components/ui/PostList.astro";
import { TechStackItem, TechStackProvider } from "@/components/TechStackItem";

const MAX_POSTS = 5;
const MAX_PROJECTS = 5;
const allPosts = await getCollection("blog");
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);

const allProjects = await getCollection("projects");
const recentProjects = sortMDByDate(allProjects)
  .filter(p => p.data.published !== false)
  .slice(0, MAX_PROJECTS);

interface StackItem {
  title: string;
  description: string;
}

const stack: Array<StackItem> = [
  {
    title: "JavaScript",
    description: "Lord Ruler of the web (alongside php maybe)",
  },
  {
    title: "TypeScript",
    description: "usable JavaScript",
  },
  {
    title: "Node.js",
    description: "javascript but now in servers and APIs",
  },
  {
    title: "Nest.js",
    description: "java of Node.js",
  },
  {
    title: "SQL",
    description: "raw language for databases (orm better)",
  },
  {
    title: "Docker",
    description: "to contain my totally worthy projects",
  },
];

---

<BaseLayout navbarActiveItemID="home">
  <MatrixBackground
    slot="background"
    highlightColor="rgba(222, 133, 74, 0.2)"
    boxSize={40}
    movementSpeed={0.1}
    movementDirection="up-left"
  />
  <main>
    <section id="about" aria-labelledby="about-heading">
      <Card role="region">
        <TerminalHeader title="terminal - ssh guest@enzom" />
        <!-- Content -->
        <div class="text-xs">
          <div class="space-y-4 sm:space-y-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="flex flex-col gap-1">
                <h1 class="text-2xl">
                  👋 Hi! I'm <span class="text-primary font-medium">Enzo</span>
                </h1>
              </div>
            </div>
            <!-- Personal paragraph -->
            <div class="bg-gray-200/50 dark:bg-gray-500/10 rounded-lg p-3 mb-4">
              <p class="text-primary leading-relaxed">
                I'm an aspiring software developer, based in Uruguay. Currently
                I'm working on some personal projects, so feel free to contact
                me for anything.
              </p>
            </div>
            <Divider class="mb-2" />
            <InfoRow label="location">Uruguay 🧉🇺🇾</InfoRow>
            <InfoRow label="main hobby">videogames</InfoRow>
            <InfoRow label="current project">
              <!-- TODO: add link to QuoteKeeper /projects route  -->
              <ExternalLink
                href=""
                label="Visit Google, an evil company"
                class="underline"
              >
                QuoteKeeper
              </ExternalLink>
            </InfoRow>
            <InfoRow label="main interests">
              videogames, coding, fantasy, movies, linux, sci-fi
            </InfoRow>
            <InfoRow label="contact">
              <a
                class="text-accent hover:underline focus:outline-none"
                href="mailto:enzom.dev@gmail.com"
                aria-label="Send email to site author">enzom.dev@gmail.com</a
              >
            </InfoRow>
            <InfoRow label="social">
              <SocialMediaIcons />
            </InfoRow>
            <div class="pt-2">
              <div class="flex flex-col sm:flex-row gap-0.5 sm:gap-0">
                <span class="text-muted sm:w-36 shrink-0">tech stack</span>
                <div
                  class="flex flex-wrap gap-2"
                  role="list"
                  aria-label="Tech stack"
                >
                  {
                    stack.map((item) => (
                      <TechStackItem
                        name={item.title}
                        description={item.description}
                        client:load
                      />
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="pt-2">
              <div class="flex flex-col sm:flex-row gap-0.5 sm:gap-0">
                <span class="text-muted sm:w-36 shrink-0">ai tools</span>
                <div
                  class="flex flex-wrap gap-2"
                  role="list"
                  aria-label="Tech stack"
                >
                  <p class="text-secondary">
                    <span class="italic">claude</span> with my beloved <a
                      href="https://opencode.ai/"
                      target="_blank"
                      class="underline">opencode</a
                    >
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Card>
      <TerminalPrompt command="cat about.txt" />
    </section>
  </main>

  <Card class="text-secondary" role="region" aria-label="Project showcase">
    <SectionHeading>💻 recent projects</SectionHeading>
    <div class="space-y-2" role="list">
      {
        recentProjects.map((project, index) => (
          <ProjectItem
            title={project.data.title}
            description={project.data.description}
            link={`/projects/${project.slug}/`}
            icon="💻"
            index={index}
            type={project.data.type}
          />
        ))
      }
    </div>
    <TerminalPrompt command={`ls -la projects/ | total ${recentProjects.length}`} />
  </Card>

{
  allPosts.length > 0 && (
    <section id="blog" class="mt-2">
      <Card>
        <SectionHeading>✍️ latest posts</SectionHeading>
        <PostList posts={allPostsByDate} />
        <TerminalPrompt command={`tail -n ${allPostsByDate.length} blog/`} />
      </Card>
    </section>
  )
}
</BaseLayout>

