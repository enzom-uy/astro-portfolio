---
import { Badge } from "@/components/ui/badge";

interface Props {
  title: string;
  description: string;
  link?: string;
  icon: string;
  index: number;
  type?: string;
}

const { title, description, link, icon, index, type } = Astro.props;
const number = String(index + 1).padStart(2, "0");
---

<div
  class="group p-1 rounded transition-colors"
  role="listitem"
>
  {
    link ? (
      <a
        href={link}
        class="block focus:outline-none rounded"
        aria-label={`Visit ${title}: ${description}`}
      >
        <div class="flex items-start gap-2 flex-wrap">
          <span class="text-muted w-6 shrink-0" aria-hidden="true">
            {number}.
          </span>
          <span
            class="text-yellow-360 shrink-0"
            role="img"
            aria-label="Project icon"
          >
            {icon}
          </span>
          <div class="min-w-0 flex-1 flex items-center gap-2">
            <span class="text-secondary group-hover:text-accent font-semibold">
              {title}
            </span>
            {type && <Badge variant="secondary" class="text-xs">{type}</Badge>}
            <span class="text-muted">
              → {description}
            </span>
          </div>
        </div>
      </a>
    ) : (
      <div
        class="flex items-start gap-2 opacity-60"
        aria-label={`${title}: ${description}`}
      >
        <span class="text-muted w-6 shrink-0" aria-hidden="true">
          {number}.
        </span>
        <span
          class="text-yellow-360 shrink-0"
          role="img"
          aria-label="Project icon"
        >
          {icon}
        </span>
        <div class="min-w-0 flex-1">
          <span class="text-secondary font-semibold block sm:inline">
            {title}
          </span>
          <span class="text-muted sm:ml-2 block sm:inline mt-1 sm:mt-0">
            → {description}
          </span>
          <span class="text-muted/70 sm:ml-2 block sm:inline">[soon]</span>
        </div>
      </div>
    )
  }
</div>
